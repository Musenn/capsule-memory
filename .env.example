# LLM configuration (litellm unified format, fill in the API Key for your model)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# CapsuleMemory configuration
CAPSULE_STORAGE_TYPE=local           # local | sqlite | redis | qdrant
CAPSULE_STORAGE_PATH=~/.capsules     # local/sqlite storage path
CAPSULE_STORAGE_URL=                 # redis://... or qdrant://...
CAPSULE_LLM_MODEL=                   # Required. litellm model string, e.g. gpt-4o-mini, deepseek/deepseek-chat, claude-haiku-4-5
CAPSULE_COMPRESS_THRESHOLD=8000      # Buffer token threshold before L1 compression triggers
CAPSULE_COMPRESS_LAYER_MAX=6000      # Max tokens per compression layer before cascade
CAPSULE_MOCK_EXTRACTOR=false         # true to skip all LLM calls, return mock data
CAPSULE_SKILL_LLM_SCORE=false        # true to enable LLM scoring for skill triggers
                                     # When enabled, detected skills are scored by LLM on 3 dimensions:
                                     # generality, reusability, completeness (each 0.0-1.0).
                                     # Average score below 0.65 causes the skill draft to be discarded.
                                     # Adds ~1-3s latency per detection. Requires valid API key.
CAPSULE_LOG_LEVEL=INFO
CAPSULE_ENCRYPT_DEFAULT=false
CAPSULE_API_KEY=                     # REST Server optional auth token (empty = no auth)
